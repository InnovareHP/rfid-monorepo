---
import { Card } from "@dashboard/ui/components/card";

const STATS = [
  { value: "1", label: "source of truth for facilities & referrals" },
  { value: "FREE", label: "free trial, no credit card" },
  { value: "15", label: "team seats included" },
  { value: "10+", label: "integrations including Gmail & Outlook" },
];

const POINTS = [
  {
    title: "For liaison & admission teams",
    body: "who juggle dozens of facility relationships and can't afford a missed follow-up.",
  },
  {
    title: "Replaces the spreadsheet maze",
    body: "— shared lists that are always current, with history on every change and restore when someone slips.",
  },
  {
    title: "Your fields, your workflow",
    body: "— add columns, statuses, and dropdowns per organization. The software adapts, not your team.",
  },
  {
    title: "Security that fits healthcare",
    body: "— role-based access, short-lived sessions, and PHI-aware AI processing.",
  },
];
---

<section id="why" class="bg-muted/50 py-16 lg:py-24">
  <div
    class="mx-auto grid w-full max-w-6xl items-center gap-12 px-6 lg:grid-cols-[1.15fr_0.85fr] lg:gap-18"
  >
    <div class="reveal">
      <h2 class="section-title">
        Built for the teams who bring the referrals in
      </h2>
      <p class="section-lead">
        Most CRMs were designed for software sales. Your liaisons work
        differently — they cover counties, visit facilities, assess patients,
        and answer to census numbers. Refidly was designed around that
        workflow from day one.
      </p>

      <ul class="mt-8 flex flex-col gap-4">
        {
          POINTS.map((point) => (
            <li class="flex items-start gap-3.5 text-[15.5px] text-muted-foreground">
              <span class="mt-0.5 grid size-5 shrink-0 place-items-center rounded-md bg-gradient-to-br from-primary to-brand-strong">
                <svg
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="white"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M20 6L9 17l-5-5" />
                </svg>
              </span>
              <span>
                <strong class="text-foreground">{point.title}</strong>{" "}
                {point.body}
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="reveal grid grid-cols-2 gap-4 max-[480px]:grid-cols-1">
      {
        STATS.map((stat) => (
          <Card className="gap-1.5 px-5 py-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
            <strong class="bg-gradient-to-r from-primary to-brand-strong bg-clip-text text-3xl font-extrabold tracking-tight text-transparent">
              {stat.value}
            </strong>
            <span class="text-[13.5px] text-muted-foreground">
              {stat.label}
            </span>
          </Card>
        ))
      }
    </div>
  </div>
</section>
