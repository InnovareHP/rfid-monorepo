---
import { buttonVariants } from "@dashboard/ui/components/button";
import { APP_URL, SUPPORT_EMAIL } from "../config";

const YEAR = new Date().getFullYear();

const PRODUCT_LINKS = [
  { href: "#features", label: "Features" },
  { href: "#how-it-works", label: "How it works" },
  { href: APP_URL, label: "Sign in" },
];

const COMPANY_LINKS = [
  { href: "#why", label: "Why Refidly" },
  { href: `mailto:${SUPPORT_EMAIL}`, label: "Contact support" },
  { href: `mailto:${SUPPORT_EMAIL}`, label: "Request a demo" },
];
---

<footer class="border-t border-border bg-muted/50 pt-16">
  <div
    class="mx-auto grid w-full max-w-6xl gap-12 px-6 pb-12 max-[860px]:grid-cols-2 max-[520px]:grid-cols-1 min-[861px]:grid-cols-[1.4fr_1fr_1fr_1fr]"
  >
    <div>
      <a
        href="/"
        class="flex items-center gap-2.5"
        aria-label="Refidly home"
      >
        <img src="/tarsier.png" alt="" width="34" height="34" loading="lazy" />
        <span class="flex flex-col leading-tight">
          <strong class="text-lg font-extrabold text-brand-strong">
            Refidly
          </strong>
          <small
            class="text-[0.6rem] font-semibold tracking-[0.09em] uppercase text-muted-foreground"
          >
            Referral Intelligence Platform
          </small>
        </span>
      </a>
      <p class="mt-4 max-w-[300px] text-sm text-muted-foreground">
        Referral intelligence for healthcare marketing and liaison teams. Track
        facilities, referrals, and field activity in one place.
      </p>
    </div>

    <nav class="flex flex-col gap-2.5" aria-label="Product links">
      <h3
        class="mb-1.5 text-[13px] font-bold tracking-wider uppercase text-muted-foreground"
      >
        Product
      </h3>
      {
        PRODUCT_LINKS.map((link) => (
          <a
            href={link.href}
            class="w-fit text-sm text-muted-foreground transition-colors hover:text-brand-strong"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <nav class="flex flex-col gap-2.5" aria-label="Company links">
      <h3
        class="mb-1.5 text-[13px] font-bold tracking-wider uppercase text-muted-foreground"
      >
        Company
      </h3>
      {
        COMPANY_LINKS.map((link) => (
          <a
            href={link.href}
            class="w-fit text-sm text-muted-foreground transition-colors hover:text-brand-strong"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex flex-col gap-2.5">
      <h3
        class="mb-1.5 text-[13px] font-bold tracking-wider uppercase text-muted-foreground"
      >
        Get started
      </h3>
      <p class="text-sm text-muted-foreground">
        Free trial. No credit card required.
      </p>
      <a
        href={APP_URL}
        class={buttonVariants({ className: "mt-1.5 w-fit" })}
      >
        Start free trial
      </a>
    </div>
  </div>

  <div
    class="mx-auto flex w-full max-w-6xl flex-wrap justify-between gap-2 border-t border-border px-6 py-5 text-[13px] text-muted-foreground"
  >
    <span>© {YEAR} Refidly. All rights reserved.</span>
    <span>Built for the teams who bring the referrals in.</span>
  </div>
</footer>
