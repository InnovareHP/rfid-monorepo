model Subscription {
  id                   String    @id @default(uuid())
  plan                 String
  referenceId          String
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?
  status               String?
  periodStart          DateTime? @db.Timestamptz(3)
  periodEnd            DateTime? @db.Timestamptz(3)
  cancelAtPeriodEnd    Boolean?
  seats                Int?
  trialStart           DateTime? @db.Timestamptz(3)
  trialEnd             DateTime? @db.Timestamptz(3)
  cancelAt             DateTime? @db.Timestamptz(3)

  @@schema("stripe_schema")
}

model Plan {
  id            String    @id @default(uuid())
  name          String
  priceId       String?
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime? @db.Timestamptz(3)
  photo         String?
  description   String?
  roleAvailable String?
  isActive      Boolean
  type          String?
  limits        Json?

  @@schema("stripe_schema")
}
