model Field {
  id         String         @id @default(uuid())
  createdAt  DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime       @updatedAt @db.Timestamptz(3)
  fieldName  String
  fieldOrder Int
  fieldType  BoardFieldType
  moduleType ModuleType     @default(LEAD)
  isDeleted  Boolean        @default(false)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  options FieldOption[]
  values  FieldValue[]

  @@index([organizationId, moduleType, isDeleted, fieldOrder])
  @@schema("board_schema")
}

model Board {
  id         String     @id @default(uuid())
  createdAt  DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime   @updatedAt @db.Timestamptz(3)
  recordName String
  assignedTo String?
  isDeleted  Boolean    @default(false)
  moduleType ModuleType @default(LEAD)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUser   User?        @relation(fields: [assignedTo], references: [id])

  values            FieldValue[]
  history           History[]
  notifications     BoardNotificationState[]
  activities        Activity[]
  relationsAsSource BoardRelation[]          @relation("RelationSource")
  relationsAsTarget BoardRelation[]          @relation("RelationTarget")

  @@index([organizationId, recordName])
  @@index([organizationId, moduleType, isDeleted, createdAt])
  @@index([assignedTo])
  @@schema("board_schema")
}

model FieldValue {
  id             String  @id @default(uuid())
  recordId       String
  fieldId        String
  value          String?
  organizationId String?

  field        Field                   @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  record       Board                   @relation(fields: [recordId], references: [id], onDelete: Cascade)
  contactValue FieldPersonInformation?

  @@unique([recordId, fieldId])
  @@index([recordId])
  @@index([fieldId, value])
  @@index([organizationId])
  @@schema("board_schema")
}

model FieldOption {
  id             String  @id @default(uuid())
  optionName     String
  color          String?
  isDeleted      Boolean @default(false)
  fieldId        String
  organizationId String?
  field          Field   @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId])
  @@index([organizationId])
  @@schema("board_schema")
}

model History {
  id             String   @id @default(uuid())
  recordId       String
  oldValue       String?
  newValue       String?
  column         String?
  action         String
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  createdBy      String?
  organizationId String?

  record Board @relation(fields: [recordId], references: [id], onDelete: Cascade)
  user   User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([recordId, createdAt])
  @@index([organizationId])
  @@schema("board_schema")
}

model FieldPersonInformation {
  id            String @id @default(uuid())
  contactNumber String
  email         String
  address       String

  fieldValueId String @unique

  fieldvalue FieldValue @relation(fields: [fieldValueId], references: [id], onDelete: Cascade)

  @@schema("board_schema")
}

model BoardNotificationState {
  id        String   @id @default(uuid())
  recordId  String   @unique
  lastSeen  DateTime @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  record Board @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@schema("board_schema")
}

model BoardCounty {
  id                    String                  @id @default(uuid())
  createdAt             DateTime                @default(now()) @db.Timestamptz(3)
  countyName            String
  organizationId        String
  boardCountyAssignedTo BoardCountyAssignedTo[]

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@schema("board_schema")
}

model BoardCountyAssignedTo {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  assignedTo String

  boardCountyId String
  boardCounty   BoardCounty @relation(fields: [boardCountyId], references: [id], onDelete: Cascade)

  @@index([boardCountyId])
  @@schema("board_schema")
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  FAX

  @@schema("board_schema")
}

enum ActivityStatus {
  PENDING
  COMPLETED
  CANCELLED

  @@schema("board_schema")
}

model Activity {
  id             String         @id @default(uuid())
  createdAt      DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime       @updatedAt @db.Timestamptz(3)
  title          String
  description    String?
  activityType   ActivityType
  status         ActivityStatus @default(PENDING)
  dueDate        DateTime?      @db.Timestamptz(3)
  completedAt    DateTime?      @db.Timestamptz(3)
  recipientEmail String?
  emailSubject   String?
  emailBody      String?
  emailSentAt    DateTime?      @db.Timestamptz(3)
  senderEmail    String?
  faxNumber      String?
  faxId          String?
  faxSentAt      DateTime?      @db.Timestamptz(3)

  recordId String
  record   Board  @relation(fields: [recordId], references: [id], onDelete: Cascade)

  createdBy String
  creator   User   @relation(fields: [createdBy], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([recordId])
  @@index([organizationId])
  @@index([dueDate])
  @@schema("board_schema")
}

model GmailToken {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime @db.Timestamptz(3)
  gmailAddress String

  @@schema("board_schema")
}

model OutlookToken {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime @db.Timestamptz(3)
  outlookEmail String

  @@schema("board_schema")
}

model BoardRelation {
  id             String       @id @default(uuid())
  createdAt      DateTime     @default(now()) @db.Timestamptz(3)
  sourceId       String
  targetId       String
  relationType   RelationType @default(REFERRAL_LINK)
  organizationId String?

  source Board @relation("RelationSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Board @relation("RelationTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, relationType])
  @@index([sourceId])
  @@index([targetId])
  @@index([organizationId])
  @@schema("board_schema")
}

enum ModuleType {
  LEAD
  REFERRAL

  @@schema("board_schema")
}

enum RelationType {
  REFERRAL_LINK
  FACILITY_LINK

  @@schema("board_schema")
}

enum BoardFieldType {
  TEXT
  NUMBER
  STATUS
  EMAIL
  PHONE
  DATE
  CHECKBOX
  DROPDOWN
  LOCATION
  TIMELINE
  MULTISELECT
  ASSIGNED_TO
  REFERRAL_LINK
  PERSON

  @@schema("board_schema")
}
