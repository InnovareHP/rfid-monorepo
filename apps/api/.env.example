# AWS — single provider for SES + Bedrock. Use IAM creds with ses:SendEmail + bedrock:InvokeModel.
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
SES_FROM_EMAIL=""
BEDROCK_MODEL_ID="amazon.nova-micro-v1:0"
BEDROCK_VISION_MODEL_ID="amazon.nova-lite-v1:0"
# scrubs PHI patterns before sending to Bedrock (defense in depth even with AWS BAA).
# Defaults to true; set "false" only with a signed AWS BAA in a HIPAA-eligible region.
AI_SCRUB_PHI="true"
# Eldon Fax (Scale plan) — key needs faxes:read + faxes:write scopes
ELDONFAX_API_KEY=""
ELDONFAX_BASE_URL="https://api.eldonfax.com"
LOG_LEVEL=""
LOG_SERVICE=""
DEBUG=""
WEBSITE_URL=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
TWILIO_AUTH_TOKEN=""
TWILIO_ACCOUNT_SID=""
